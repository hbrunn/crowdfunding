<odoo>
    <record id="view_crowdfunding_tag_form" model="ir.ui.view">
        <field name="model">crowdfunding.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                    <group>
                        <group name="left">
                            <field name="active" invisible="True" />
                            <field name="name"/>
                        </group>
                        <group name="right">
                            <field
                                name="company_id"
                                groups="base.group_multi_company"
                            />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_crowdfunding_tag_list" model="ir.ui.view">
        <field name="model">crowdfunding.tag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="company_id" groups="base.group_multi_company" />
            </tree>
        </field>
    </record>

    <record id="view_crowdfunding_tag_search" model="ir.ui.view">
        <field name="model">crowdfunding.tag</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" />
                <separator/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_crowdfunding_tag" model="ir.actions.act_window">
        <field name="name">Tags</field>
        <field name="res_model">crowdfunding.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>